Class {
	#name : #SRPooledObject,
	#superclass : #Object,
	#instVars : [
		'internalObject',
		'internalObjectIndex',
		'internalObjectPool'
	],
	#classInstVars : [
		'pool',
		'poolSize',
		'internalClass'
	],
	#category : #'SqueakXR-Pool'
}

{
	#category : #'as yet unclassified',
	#'squeak_changestamp' : 'lege 4/7/2026 11:44'
}
SRPooledObject class >> createPool [

	self assert: internalClass notNil.
	
	^ SRObjectPool
		createFor: self internalClass
		withSize: self poolSize
]

{
	#category : #'as yet unclassified',
	#'squeak_changestamp' : 'lege 4/7/2026 12:16'
}
SRPooledObject class >> generateMethod: aMethod [

	self compile: (self methodSourceFor: aMethod) classified: '*autogenerated - methods'
]

{
	#category : #'as yet unclassified',
	#'squeak_changestamp' : 'lege 4/7/2026 12:17'
}
SRPooledObject class >> generateMethods [

	self internalClass methodsDo: [:method |
		self generateMethod: method]
]

{
	#category : #'as yet unclassified',
	#'squeak_changestamp' : 'lege 4/7/2026 18:10'
}
SRPooledObject class >> initialize [

	super initialize.
	
	self = SRPooledObject ifFalse: [
		Smalltalk addToStartUpList: self]
]

{
	#category : #'as yet unclassified',
	#'squeak_changestamp' : 'lege 4/7/2026 11:43'
}
SRPooledObject class >> internalClass [

	^ internalClass
]

{
	#category : #'as yet unclassified',
	#'squeak_changestamp' : 'lege 4/7/2026 11:49'
}
SRPooledObject class >> internalClass: aClass [

	"make sure that the internal class is not set for the superclass"
	self assert: self ~= SRPooledObject.
	internalClass := aClass.
]

{
	#category : #'as yet unclassified',
	#'squeak_changestamp' : 'lege 4/7/2026 12:16'
}
SRPooledObject class >> methodSourceFor: aMethod [

	| selectorWithArgs |
	selectorWithArgs := aMethod decompileString lines first.

	^ '{1}
	
		^ self internalObject {1}' format: {selectorWithArgs}
]

{
	#category : #'as yet unclassified',
	#'squeak_changestamp' : 'lege 4/7/2026 17:01'
}
SRPooledObject class >> new [

	| internalObjectInfo |
	internalObjectInfo := self pool nextObject.
	^ self basicNew initialize;
		internalObject: internalObjectInfo first
		withIndex: internalObjectInfo second
		inPool: internalObjectInfo third
]

{
	#category : #'as yet unclassified',
	#'squeak_changestamp' : 'lege 4/6/2026 20:20'
}
SRPooledObject class >> pool [

	^ pool ifNil: [pool := self createPool]
]

{
	#category : #'as yet unclassified',
	#'squeak_changestamp' : 'lege 4/7/2026 15:05'
}
SRPooledObject class >> poolSize [

	^ poolSize ifNil: [^ 3]
]

{
	#category : #'as yet unclassified',
	#'squeak_changestamp' : 'lege 4/6/2026 20:21'
}
SRPooledObject class >> poolSize: anInteger [

	poolSize := anInteger
]

{
	#category : #'as yet unclassified',
	#'squeak_changestamp' : 'lege 4/7/2026 15:02'
}
SRPooledObject class >> resetPool [

	pool := nil
]

{
	#category : #'as yet unclassified',
	#'squeak_changestamp' : 'lege 4/7/2026 18:18'
}
SRPooledObject class >> startUp: resuming [

	resuming ifTrue: [
		self resetPool.
		self allInstancesDo: [:instance |
			instance resetInternalObject]]
]

{
	#category : #'as yet unclassified',
	#'squeak_changestamp' : 'lege 4/7/2026 11:50'
}
SRPooledObject class >> subclassFor: aClass named: aSymbol [

	^ (self subclass: aSymbol
		instanceVariableNames: ''
		classVariableNames: ''
		poolDictionaries: ''
		category: self category, '-Generated')
		internalClass: aClass;
		generateMethods
]

{
	#category : #'as yet unclassified',
	#'squeak_changestamp' : 'lege 4/7/2026 18:18'
}
SRPooledObject >> finalize [

	self internalPool ifNotNil: [:pool | pool release: self].
	self resetInternalObject.
]

{
	#category : #'as yet unclassified',
	#'squeak_changestamp' : 'lege 4/7/2026 16:03'
}
SRPooledObject >> initialize [

	FinalizationRegistry default add: self
]

