{
	#category : #generating,
	#'squeak_changestamp' : 'lege 11/18/2025 16:00'
}
SRFFIGenerator >> extendAliasTable [

	self aliasTable addAll:
		(self apiSpec aliases
			collect: [:aliasSpec |
				aliasSpec name -> (self normalizedType: aliasSpec type)])
]

