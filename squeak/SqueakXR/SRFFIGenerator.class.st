{
	#category : #names,
	#'squeak_changestamp' : 'lege 11/18/2025 11:24'
}
SRFFIGenerator >> isApiType: aString [

	(Smalltalk classNamed: aString) ifNotNil: [:class |
		^ (class inheritsFrom: ExternalObject) and:
			[self class structLookupCategories anySatisfy: [:cat | cat match: class category]]].
	
	^ false
]

{
	#category : #names,
	#'squeak_changestamp' : 'lege 11/18/2025 11:24'
}
SRFFIGenerator >> isEnumType: aString [

	(Smalltalk classNamed: aString) ifNotNil: [:class |
		^ class category = self enumCategory].
	
	^ false
]

{
	#category : #names,
	#'squeak_changestamp' : 'lege 11/17/2025 18:09'
}
SRFFIGenerator >> isExcludeName: aString [

	^ self excludeNames anySatisfy: [:s | aString includesSubstring: s]
]

