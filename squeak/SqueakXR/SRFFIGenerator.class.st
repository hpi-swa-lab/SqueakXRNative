{
	#category : #generating,
	#'squeak_changestamp' : 'lege 11/18/2025 11:26'
}
SRFFIGenerator >> compileExtraMethods [

	self extraMethods ifNotNil: [
		self extraMethods keysAndValuesDo: [:class :source |
			(Smalltalk classNamed: class) compile: source]]
]

{
	#category : #names,
	#'squeak_changestamp' : 'lege 11/17/2025 18:06'
}
SRFFIGenerator >> convertToClassName: aString [

	^ (self prefix, aString capitalized) asSymbol
]

{ #category : #generating }
SRFFIGenerator >> createAliasTable [

	self aliasTable:
		(self apiSpec aliases
			collect: [:aliasSpec |
				aliasSpec name -> (self class convertToClassName: aliasSpec type)]
			as: Dictionary)
]

{ #category : #generating }
SRFFIGenerator >> descriptionFor: aJsonSpec [

	^ {
		aJsonSpec description.
		aJsonSpec params
			ifNil: ['']
			ifNotNil: [:params | params collect: [:param | String tab, param name, ' - ', param type]]
	} flatten joinSeparatedBy: String cr
]

{
	#category : #names,
	#'squeak_changestamp' : 'lege 11/17/2025 18:06'
}
SRFFIGenerator >> enumCategory [

	^ self categoryName: 'Enum'
]

