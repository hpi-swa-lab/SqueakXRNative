{ #category : #generating }
SRFFIGenerator >> resetAliasTable [

	self aliasTable: Dictionary new
]

{ #category : #generating }
SRFFIGenerator >> resolveRaylibType: aString [

	self aliasTable
		at: aString
		ifPresent: [:alias | ^ alias].
	
	(self class isApiType: aString) ifTrue: [^ aString].
	
	((self class isEnumType: aString) or: [aString asLowercase includesSubstring: 'enum']) ifTrue: [^ 'int'].
	
	^ self class convertToClassName: aString
]

{
	#category : #generating,
	#'squeak_changestamp' : 'lege 11/18/2025 11:25'
}
SRFFIGenerator >> resolveType: aString [

	self aliasTable
		at: aString
		ifPresent: [:alias | ^ alias].
	
	(self isApiType: aString) ifTrue: [^ aString].
	
	((self isEnumType: aString) or: [aString asLowercase includesSubstring: 'enum']) ifTrue: [^ 'int'].
	
	^ self convertToClassName: aString
]

{ #category : #generating }
SRFFIGenerator >> setComment: aString forClass: aClass [

	aClass comment: aString, String cr, String cr, self class generationSignature.
]

{ #category : #generating }
SRFFIGenerator >> signatureFor: aJsonSpec [

	| parameters |
	parameters := aJsonSpec params
		ifNil: ['']
		ifNotNil: [:params |
			(params collect: [:paramSpec | self normalizedType: paramSpec type])
				joinSeparatedBy: ', '].

	^ '{1} ''{2}'' ({3})' format: {
		self normalizedType: aJsonSpec returnType.
		aJsonSpec name.
		parameters.
	}
]

{ #category : #sourceTemplates }
SRFFIGenerator >> sourceAlias: aTypeString [

	^ 'originalTypeName
	<generated>
	^ ''{1}''' format: {
	self class convertToClassName: aTypeString.
	}
]

{ #category : #sourceTemplates }
SRFFIGenerator >> sourceEnumName: aNameString value: anInteger description: aDescriptionString [

	^ '{1}
	"{2}"
	<generated>
	^ {3}' format: {
	aNameString.
	aDescriptionString.
	anInteger}
]

{ #category : #sourceTemplates }
SRFFIGenerator >> sourceFunction: name arguments: arguments description: description signature: signature [

	^ '{1}{2}
	"{3}"
	<generated>
	<cdecl: {4}>
	^ self externalCallFailed' format: {
		name.
		arguments.
		description.
		signature.
	}
]

{ #category : #sourceTemplates }
SRFFIGenerator >> sourceFunction: name description: description signature: signature [

	^ '{1}
	"{2}"
	<generated>
	<cdecl: {3}>
	^ self externalCallFailed' format: {
		name.
		description.
		signature.
	}
]

{
	#category : #sourceTemplates,
