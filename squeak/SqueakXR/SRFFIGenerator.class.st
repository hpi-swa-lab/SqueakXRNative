}
SRFFIGenerator >> sourceModuleName [

	^ 'moduleName

	^ ''{1}''' format: {self moduleName}
]

{ #category : #sourceTemplates }
SRFFIGenerator >> sourceStructFields: aFieldsArray [

	^ 'fields
	<generated>
	^ {1}' format: {aFieldsArray}
]

