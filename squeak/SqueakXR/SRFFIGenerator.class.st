Class {
	#name : #SRFFIGenerator,
	#superclass : #Object,
	#instVars : [
		'apiSpec',
		'functionClass',
		'aliasTable',
		'streams',
		'extraMethods',
		'functionGlobal',
		'prefix',
		'categoryName',
		'baseCategoryName',
		'excludeNames',
		'moduleName'
	],
	#category : #'SqueakXR-Other'
}

{
	#category : #apis,
	#'squeak_changestamp' : 'lege 11/18/2025 11:09'
}
SRFFIGenerator class >> baseCategoryOpenAL [
		
	^ 'OpenAL'
]

{
	#category : #apis,
	#'squeak_changestamp' : 'lege 11/18/2025 11:09'
}
SRFFIGenerator class >> baseCategoryRaylib [
		
	^ 'Raylib'
]

{
	#category : #apis,
	#'squeak_changestamp' : 'lege 11/18/2025 11:26'
}
SRFFIGenerator class >> extraRaylibMethods [

	^ {
		#RlVector3 -> 'asVector3 ^ Vector3 x: self x y: self y z: self z'.
	} asDictionary
]

{ #category : #generating }
SRFFIGenerator class >> generateFromFile: aFilepathString [

	self generateFromFiles: {aFilepathString}
]

{ #category : #generating }
SRFFIGenerator class >> generateFromFiles: aStringCollection [

	self generateFromStreams: (aStringCollection collect: [:filepath | (FileStream readOnlyFileNamed: filepath)])
]

{ #category : #generating }
SRFFIGenerator class >> generateFromRemoteFile: aUrlString [

	self generateFromStream: (WebClient httpGet: aUrlString) content readStream
]

{ #category : #generating }
SRFFIGenerator class >> generateFromRepository [

	self generateFromRemoteFile: 'https://raw.githubusercontent.com/raysan5/raylib/refs/heads/master/parser/output/raylib_api.json'
]

{ #category : #generating }
SRFFIGenerator class >> generateFromStream: aStream [

	self generateFromStreams: {aStream}
]

{ #category : #generating }
SRFFIGenerator class >> generateFromStreams: aStreamCollection [

	self new
		streams: aStreamCollection;
		generate
]

{
	#category : #apis,
	#'squeak_changestamp' : 'lege 11/18/2025 16:22'
}
SRFFIGenerator class >> generateOpenALApiFromFile: aFilepath [

	self removeOpenAL.
	
	self new
		streams: {FileStream readOnlyFileNamed: aFilepath};
		prefix: 'Al';
		baseCategoryName: self baseCategoryOpenAL;
		functionGlobal: #OpenAL;
		moduleName: 'openal';
		generate
]

{
	#category : #apis,
	#'squeak_changestamp' : 'lege 11/18/2025 16:22'
}
SRFFIGenerator class >> generateRaylibApiFromFiles: aCollectionOfFilepaths [

	self removeRaylib.

	self new
		streams: (aCollectionOfFilepaths collect: [:filepath | (FileStream readOnlyFileNamed: filepath)]);
		prefix: 'Rl';
		baseCategoryName: self baseCategoryRaylib;
		functionGlobal: #Raylib;
		excludeNames: #(audio Audio sound Sound music Music rlglData);
		extraMethods: self extraRaylibMethods;
		moduleName: 'squeakxrnative';
		generate
]

{ #category : #names }
SRFFIGenerator class >> generationSignature [

	^ 'Generated by ', self name
]

{
	#category : #names,
	#'squeak_changestamp' : 'lege 11/18/2025 11:03'
}
SRFFIGenerator class >> matchAllCategory: aCategoryName [

	^ aCategoryName, '-*-Generated'
]

{
	#category : #apis,
	#'squeak_changestamp' : 'lege 11/18/2025 11:09'
}
SRFFIGenerator class >> removeOpenAL [

	Smalltalk organization removeCategoriesMatching: (self matchAllCategory: self baseCategoryOpenAL)
]

{
	#category : #apis,
	#'squeak_changestamp' : 'lege 11/18/2025 11:09'
}
SRFFIGenerator class >> removeRaylib [

	Smalltalk organization removeCategoriesMatching: (self matchAllCategory: self baseCategoryRaylib)
]

{ #category : #names }
SRFFIGenerator class >> screamingSnakeCaseToCamelCase: aString [

	^ ((aString findTokens: '_')
		collect: [:s | s asLowercase capitalized])
		join withFirstCharacterDownshifted
]

{ #category : #'as yet unclassified' }
SRFFIGenerator class >> structLookupCategories [

	^ {'OpenXR-*-Generated'}
]

