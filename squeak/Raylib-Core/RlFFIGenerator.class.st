Class {
	#name : #RlFFIGenerator,
	#superclass : #Object,
	#instVars : [
		'apiSpec',
		'functionClass',
		'aliasTable',
		'streams'
	],
	#category : #'Raylib-Core'
}

{ #category : #names }
RlFFIGenerator class >> aliasCategory [

	^ self categoryName: 'Aliases'
]

{ #category : #names }
RlFFIGenerator class >> categoryName: aString [

	^ 'Raylib-', aString, '-Generated'
]

{ #category : #names }
RlFFIGenerator class >> classPrefix [

	^ 'Rl'
]

{ #category : #names }
RlFFIGenerator class >> convertToClassName: aString [

	^ (self classPrefix, aString capitalized) asSymbol
]

{ #category : #names }
RlFFIGenerator class >> enumCategory [

	^ self categoryName: 'Enum'
]

{ #category : #names }
RlFFIGenerator class >> excludeNames [

	^ #(audio Audio sound Sound music Music)
]

{ #category : #names }
RlFFIGenerator class >> functionCategory [

	^ self categoryName: 'Functions'
]

{ #category : #names }
RlFFIGenerator class >> functionClassName [

	^ self convertToClassName: 'Functions'
]

{ #category : #generating }
RlFFIGenerator class >> generateFromFile: aFilepathString [

	self generateFromFiles: {aFilepathString}
]

{ #category : #generating }
RlFFIGenerator class >> generateFromFiles: aStringCollection [

	self generateFromStreams: (aStringCollection collect: [:filepath | (FileStream readOnlyFileNamed: filepath)])
]

{ #category : #generating }
RlFFIGenerator class >> generateFromRemoteFile: aUrlString [

	self generateFromStream: (WebClient httpGet: aUrlString) content readStream
]

{ #category : #generating }
RlFFIGenerator class >> generateFromRepository [

	self generateFromRemoteFile: 'https://raw.githubusercontent.com/raysan5/raylib/refs/heads/master/parser/output/raylib_api.json'
]

{ #category : #generating }
RlFFIGenerator class >> generateFromStream: aStream [

	self generateFromStreams: {aStream}
]

{ #category : #generating }
RlFFIGenerator class >> generateFromStreams: aStreamCollection [

	self new
		streams: aStreamCollection;
		generate
]

{ #category : #names }
RlFFIGenerator class >> generationSignature [

	^ 'Generated by ', self name
]

{ #category : #'as yet unclassified' }
RlFFIGenerator class >> isApiType: aString [

	(Smalltalk classNamed: aString) ifNotNil: [:class |
		^ (class inheritsFrom: ExternalObject) and:
			[self structLookupCategories includes: class category]].
	
	^ false
]

{ #category : #'as yet unclassified' }
RlFFIGenerator class >> isEnumType: aString [

	(Smalltalk classNamed: aString) ifNotNil: [:class |
		^ class category = self enumCategory].
	
	^ false
]

{ #category : #names }
RlFFIGenerator class >> isExcludeName: aString [

	^ self excludeNames anySatisfy: [:s | aString includesSubstring: s]
]

{ #category : #names }
RlFFIGenerator class >> matchAllCategory [

	^ self categoryName: '*'
]

{ #category : #cleanup }
RlFFIGenerator class >> removeGeneratedCategories [

	Smalltalk environment organization removeCategoriesMatching: self matchAllCategory
]

{ #category : #names }
RlFFIGenerator class >> screamingSnakeCaseToCamelCase: aString [

	^ ((aString findTokens: '_')
		collect: [:s | s asLowercase capitalized])
		join withFirstCharacterDownshifted
]

{ #category : #names }
RlFFIGenerator class >> structCategory [

	^ self categoryName: 'Structs'
]

{ #category : #'as yet unclassified' }
RlFFIGenerator class >> structLookupCategories [

	^ {'Vulkan-Generated'}
]

{ #category : #accessing }
RlFFIGenerator >> aliasTable [

	^ aliasTable
]

{ #category : #accessing }
RlFFIGenerator >> aliasTable: aDictionary [

	aliasTable := aDictionary
]

{ #category : #accessing }
RlFFIGenerator >> apiSpec [

	^ apiSpec
]

{ #category : #accessing }
RlFFIGenerator >> apiSpec: aJsonObject [

	apiSpec := aJsonObject
]

{ #category : #generating }
RlFFIGenerator >> createAliasTable [

	self aliasTable:
		(self apiSpec aliases
			collect: [:aliasSpec |
				aliasSpec name -> (self class convertToClassName: aliasSpec type)]
			as: Dictionary)
]

{ #category : #generating }
RlFFIGenerator >> descriptionFor: aJsonSpec [

	^ {
		aJsonSpec description.
		aJsonSpec params
			ifNil: ['']
			ifNotNil: [:params | params collect: [:param | String tab, param name, ' - ', param type]]
	} flatten joinSeparatedBy: String cr
]

{ #category : #generating }
RlFFIGenerator >> extendAliasTable [

	self aliasTable addAll:
		(self apiSpec aliases
			collect: [:aliasSpec |
				aliasSpec name -> (self class convertToClassName: aliasSpec type)])
]

{ #category : #accessing }
RlFFIGenerator >> functionClass [

	^ functionClass
]

{ #category : #accessing }
RlFFIGenerator >> functionClass: aClass [

	functionClass := aClass
]

{ #category : #generating }
RlFFIGenerator >> generate [

	self streams ifNil: [
		self error: 'Cannot generate without streams!'.
		^ self].
	
	UIManager default informUser: 'Generating Raylib API' during: [
		self class removeGeneratedCategories.
	
		self resetAliasTable.
	
		self streams do: [:stream |
			self apiSpec: (Json readFrom: stream);
				extendAliasTable;
				generateEnums;
				"generateAliases;"
				generateStructs;
				generateFunctions]
			displayingProgress: [:stream | stream asString].
	
		Smalltalk at: #Raylib put: self functionClass new].
]

{ #category : #generating }
RlFFIGenerator >> generateAlias: aJsonSpec [

	| class |
	(self class isExcludeName: aJsonSpec name) ifTrue: [^ self].
	
	class := ExternalTypeAlias
		subclass: (self class convertToClassName: aJsonSpec name)
		instanceVariableNames: ''
		classVariableNames: ''
		poolDictionaries: ''
		category: self class aliasCategory.
	
	self setComment: aJsonSpec description forClass: class.
	
	class class compile: (self sourceAlias: aJsonSpec type)
]

{ #category : #generating }
RlFFIGenerator >> generateAliases [

	self apiSpec aliases
		do: [:aliasSpec | self generateAlias: aliasSpec]
		displayingProgress: [:aliasSpec | 'Generating alias ', aliasSpec name]
]

{ #category : #generating }
RlFFIGenerator >> generateEnum: aJsonSpec [

	| class |
	(self class isExcludeName: aJsonSpec name) ifTrue: [^ self].
	
	class := Object
		subclass: (self class convertToClassName: aJsonSpec name)
		instanceVariableNames: ''
		classVariableNames: ''
		poolDictionaries: ''
		category: self class enumCategory.
	
	self setComment: aJsonSpec description forClass: class.
	
	(aJsonSpec at: #values) do: [:valueSpec |
		class class compile: (self
			sourceEnumName: (self class screamingSnakeCaseToCamelCase: valueSpec name)
			value: valueSpec value
			description: valueSpec description)]
]

{ #category : #generating }
RlFFIGenerator >> generateEnums [

	 self apiSpec enums
		do: [:enumSpec | self generateEnum: enumSpec]
		displayingProgress: [:enumSpec | 'Generating enum ', enumSpec name]
]

{ #category : #generating }
RlFFIGenerator >> generateFunction: aJsonSpec [

	(self class isExcludeName: aJsonSpec name) ifTrue: [^ self].
	"Don't generate variadic functions"
	aJsonSpec params ifNotNil: [:params |
		(params anySatisfy: [:param |
			param type = #'...'])
				ifTrue: [^ self]].
	
	self functionClass compile:
		(self sourceFunction: aJsonSpec name asLegalSelector
			arguments: (self parametersFor: aJsonSpec)
			description: (self descriptionFor: aJsonSpec)
			signature: (self signatureFor: aJsonSpec))
]

{ #category : #generating }
RlFFIGenerator >> generateFunctions [

	self functionClass: (ExternalLibrary
		subclass: self class functionClassName
		instanceVariableNames: ''
		classVariableNames: ''
		poolDictionaries: ''
		category: self class functionCategory).
	
	self functionClass class compile: self sourceModuleName.

	self apiSpec functions
		do: [:functionSpec | self generateFunction: functionSpec]
		displayingProgress: [:functionSpec | 'Generating function ', functionSpec name].
]

{ #category : #generating }
RlFFIGenerator >> generateStruct: aJsonSpec [

	| class |
	(self class isExcludeName: aJsonSpec name) ifTrue: [^ self].
	
	class := ExternalStructure
		subclass: (self class convertToClassName: aJsonSpec name)
		instanceVariableNames: ''
		classVariableNames: ''
		poolDictionaries: ''
		category: self class structCategory.
	
	self setComment: aJsonSpec description forClass: class.
	
	class class compile: (self sourceStructFields: (self normalizedFields: aJsonSpec fields)).
]

{ #category : #generating }
RlFFIGenerator >> generateStructs [

	self apiSpec structs
		do: [:structSpec | self generateStruct: structSpec]
		displayingProgress: [:structSpec | 'Generating struct ', structSpec name]
]

{ #category : #generating }
RlFFIGenerator >> normalizedFields: aJsonSpecArray [

	^ aJsonSpecArray collect: [:spec |
		{spec name. self normalizedType: spec type}]
]

{ #category : #generating }
RlFFIGenerator >> normalizedType: aTypeString [

	| components isUnsigned normalizedPrimitive pointerToken arraySplit subscript type |
	components := aTypeString findTokens.
	components remove: #const ifAbsent: [].
	
	pointerToken := (components select: [:token | token includes: $*])
		ifEmpty: ['']
		ifNotEmpty: [:tokens |
			tokens size > 1 ifTrue: [self error: 'Unexpected number of pointer tokens'].
			components remove: tokens first.
			tokens first].
	
	pointerToken size > 1 ifTrue: [
		"self flag: 'defineFields fails for pointer to pointers. Could this work better?'."
		^ 'void*'].
	
	isUnsigned := false.
	(components includes: #unsigned) ifTrue: [
		isUnsigned := true.
		components remove: #unsigned].
	
	components size = 1 ifFalse: [
		self error: 'Unexpected type format: ', aTypeString].

	arraySplit := components first splitBy: '['.
	type := arraySplit first.
	subscript := arraySplit at: 2
		ifPresent: [:s | '[', s]
		ifAbsent: [''].
	
	normalizedPrimitive := type caseOf: {
		[#void] -> ['void'].
		[#bool] -> ['bool'].
		[#char] -> ['char8_t'].
		[#short] -> ['int16_t'].
		[#int] -> ['intptr_t'].
		[#float] -> ['float'].
		[#double] -> ['double']
		} otherwise: [self resolveRaylibType: type].
	
	^ '{1}{2}{3}{4}' format: {
		isUnsigned ifTrue: ['u'] ifFalse: [''].
		normalizedPrimitive.
		pointerToken.
		subscript.
	}
]

{ #category : #generating }
RlFFIGenerator >> parametersFor: aJsonSpec [

	| firstParam paramNames |
	aJsonSpec params ifNil: [^ ''].
	
	paramNames := aJsonSpec params collect: [:param | param name] as: OrderedCollection.
	
	firstParam := ((aJsonSpec name asLowercase endsWith: paramNames first asLowercase)
		ifTrue: ['']
		ifFalse: [paramNames first capitalized]), ': ', paramNames first.
	paramNames removeFirst.
	
	^ {firstParam. paramNames collect: [:param | param, ': ', param]} flatten joinSeparatedBy: ' '
]

{ #category : #generating }
RlFFIGenerator >> resetAliasTable [

	self aliasTable: Dictionary new
]

{ #category : #generating }
RlFFIGenerator >> resolveRaylibType: aString [

	self aliasTable
		at: aString
		ifPresent: [:alias | ^ alias].
	
	(self class isApiType: aString) ifTrue: [^ aString].
	
	((self class isEnumType: aString) or: [aString asLowercase includesSubstring: 'enum']) ifTrue: [^ 'int'].
	
	^ self class convertToClassName: aString
]

{ #category : #generating }
RlFFIGenerator >> setComment: aString forClass: aClass [

	aClass comment: aString, String cr, String cr, self class generationSignature.
]

{ #category : #generating }
RlFFIGenerator >> signatureFor: aJsonSpec [

	| parameters |
	parameters := aJsonSpec params
		ifNil: ['']
		ifNotNil: [:params |
			(params collect: [:paramSpec | self normalizedType: paramSpec type])
				joinSeparatedBy: ', '].

	^ '{1} ''{2}'' ({3})' format: {
		self normalizedType: aJsonSpec returnType.
		aJsonSpec name.
		parameters.
	}
]

{ #category : #sourceTemplates }
RlFFIGenerator >> sourceAlias: aTypeString [

	^ 'originalTypeName
	<generated>
	^ ''{1}''' format: {
	self class convertToClassName: aTypeString.
	}
]

{ #category : #sourceTemplates }
RlFFIGenerator >> sourceEnumName: aNameString value: anInteger description: aDescriptionString [

	^ '{1}
	"{2}"
	<generated>
	^ {3}' format: {
	aNameString.
	aDescriptionString.
	anInteger}
]

{ #category : #sourceTemplates }
RlFFIGenerator >> sourceFunction: name arguments: arguments description: description signature: signature [

	^ '{1}{2}
	"{3}"
	<generated>
	<cdecl: {4}>
	^ self externalCallFailed' format: {
		name.
		arguments.
		description.
		signature.
	}
]

{ #category : #sourceTemplates }
RlFFIGenerator >> sourceFunction: name description: description signature: signature [

	^ '{1}
	"{2}"
	<generated>
	<cdecl: {3}>
	^ self externalCallFailed' format: {
		name.
		description.
		signature.
	}
]

{ #category : #sourceTemplates }
RlFFIGenerator >> sourceModuleName [

	^ 'moduleName

	^ ''squeakxrnative'''
]

{ #category : #sourceTemplates }
RlFFIGenerator >> sourceStructFields: aFieldsArray [

	^ 'fields
	<generated>
	^ {1}' format: {aFieldsArray}
]

{ #category : #accessing }
RlFFIGenerator >> streams [

	^ streams
]

{ #category : #accessing }
RlFFIGenerator >> streams: aStreamCollection [

	streams := aStreamCollection
]
